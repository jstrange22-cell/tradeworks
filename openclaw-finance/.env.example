# =============================================================================
# TradeWorks APEX — Environment Variables
# =============================================================================

# -- TradeWorks Gateway --
TRADEWORKS_GATEWAY_URL=http://localhost:4000
APEX_JWT_TOKEN=
APEX_HMAC_SECRET=

# -- LLM Providers --
ANTHROPIC_API_KEY=              # Claude Opus 4.5 (primary)
DEEPSEEK_API_KEY=               # DeepSeek (fallback)

# -- Crypto Exchanges --
CDP_API_KEY_NAME=               # Coinbase CDP key name
CDP_API_KEY_SECRET=             # Coinbase CDP private key (Ed25519)

# -- Equities --
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true               # Set to false for live stock trading

# -- Solana --
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# NEVER store wallet private keys in .env — use encrypted vault or hardware wallet

# -- Jupiter (Solana DEX routing) --
JUPITER_API_KEY=                # Free at portal.jup.ag

# -- Prediction Markets --
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=

# -- Sports Betting --
ODDS_API_KEY=                   # Free at the-odds-api.com (500 req/month)

# -- Market Data --
DEXSCREENER_API_KEY=            # Optional (free tier works)
BIRDEYE_API_KEY=
COINGECKO_API_KEY=              # Optional (free tier works)

# -- Token Security --
GOPLUS_API_KEY=                 # Optional (free tier works)

# -- News & Sentiment --
TAVILY_API_KEY=

# -- Notifications --
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -- Google OAuth --
GOOGLE_CLIENT_ID=

# -- OpenClaw Runtime --
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_HOOK_TOKEN=
