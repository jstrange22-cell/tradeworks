# Copy this to .env and fill in the secret. Bridge requires TradingView Desktop
# launched with --remote-debugging-port=9222 (use scripts/launch_tv_debug.bat).

# Webhook URL of the deployed gateway. Includes the shared-secret query param.
TRADINGVIEW_WEBHOOK_URL=https://ai.pulsiq.ai/api/v1/webhooks/tradingview?secret=REPLACE_ME

# CDP target (TV Desktop debug port).
CDP_HOST=localhost
CDP_PORT=9222

# Poll cadence. 30s default — gives the chart time to render new bars without
# hammering CDP.
POLL_INTERVAL_MS=30000

# Pine indicator whose labels we monitor. Keep "APEX Webhook Bridge" unless
# you've replaced it with a custom Pine that emits label.new() on BUY/SELL.
BRIDGE_INDICATOR_NAME=APEX Webhook Bridge

# State file (last-seen label IDs per symbol|timeframe). Survives restarts.
BRIDGE_STATE_FILE=./data/state.json

# Set to true to log signals without POSTing — useful for first-run testing.
DRY_RUN=false

# Log verbosity: trace, debug, info, warn, error.
LOG_LEVEL=info
