# Optional: enable Claude API for qualitative rerank of watchlist picks.
# Without this, the scout uses deterministic momentum/ATR scoring only.
ANTHROPIC_API_KEY=

# How often to refresh the watchlist (hours).
SCOUT_REFRESH_HOURS=4

# Refresh only during stock market hours (8am-5pm ET, Mon-Fri).
# Set to false to refresh 24/7 (good if crypto is the priority).
SCOUT_MARKET_HOURS_ONLY=true

# Where to write watchlist.json. Gateway reads this same path.
SCOUT_OUTPUT_FILE=./data/watchlist.json

LOG_LEVEL=info
