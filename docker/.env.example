# TradeWorks Production Environment Variables
# Copy this to .env and fill in values

# Database
POSTGRES_USER=tradeworks
POSTGRES_PASSWORD=your_secure_password_here

# Redis
REDIS_PASSWORD=your_redis_password_here

# Gateway
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_32_byte_hex_key_here
CORS_ORIGIN=https://dashboard.tradeworks.io

# Engine
PAPER_TRADING=true
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Exchange API Keys (set via Settings UI, encrypted in DB)
# COINBASE_API_KEY=
# COINBASE_API_SECRET=
# ALPACA_API_KEY=
# ALPACA_API_SECRET=

# Caddy (reverse proxy)
DOMAIN=dashboard.tradeworks.io
