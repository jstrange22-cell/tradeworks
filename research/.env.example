# Copy to .env and fill in. Never commit .env.
#
# Polygon.io REST API for stocks (paid tier for full historicals).
POLYGON_API_KEY=

# Alpaca Markets — used for live + historical equities.
# Set ALPACA_BASE_URL=https://paper-api.alpaca.markets for paper trading.
ALPACA_KEY=
ALPACA_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Finnhub — fundamentals, earnings dates (PEAD strategy).
FINNHUB_API_KEY=

# Birdeye — Solana token data (memecoin strategies).
BIRDEYE_API_KEY=

# Coinbase Advanced Trade — CDP Ed25519 JWT auth (basis/grid strategies).
COINBASE_API_KEY_NAME=
COINBASE_PRIVATE_KEY=
