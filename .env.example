# ===================================
# TradeWorks Configuration
# ===================================
# Copy to .env and fill in values.
# Variables with defaults shown are optional.

# ---------------------------------------------------------------------------
# Database — PostgreSQL (Drizzle ORM)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://tradeworks:tradeworks_dev@localhost:5432/tradeworks
PG_POOL_MAX=20                       # max pool connections
PG_IDLE_TIMEOUT=30000                # idle timeout (ms)
PG_CONNECT_TIMEOUT=5000              # connection timeout (ms)

# ---------------------------------------------------------------------------
# Database — ClickHouse (market data & analytics)
# ---------------------------------------------------------------------------
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=tradeworks
CLICKHOUSE_TIMEOUT=30000             # request timeout (ms)

# ---------------------------------------------------------------------------
# Database — Redis (pub/sub & cache)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# API Gateway
# ---------------------------------------------------------------------------
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRY=24h
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000           # rate limit window (ms)
RATE_LIMIT_MAX=100                   # max requests per window

# ---------------------------------------------------------------------------
# Engine — Orchestrator
# ---------------------------------------------------------------------------
PAPER_TRADING=true
CYCLE_INTERVAL_MS=300000             # 5 minutes
ENABLED_MARKETS=crypto               # crypto,equity,prediction
INSTRUMENTS_CRYPTO=BTC_USDT,ETH_USDT
INSTRUMENTS_EQUITY=                  # e.g. SPY,QQQ,AAPL
INSTRUMENTS_PREDICTION=              # Polymarket condition IDs
MAX_CYCLES=0                         # 0 = unlimited
MIN_CONFIDENCE=0.6                   # minimum signal confidence
REQUIRE_UNANIMITY=false              # require all agents to agree
MAX_TRADES_PER_CYCLE=5
INITIAL_EQUITY=10000
USE_CLAUDE_AGENTS=false              # true = use Claude AI for analysis agents

# ---------------------------------------------------------------------------
# Engine — Target Allocation (must sum to 1.0)
# ---------------------------------------------------------------------------
TARGET_ALLOC_CRYPTO=0.40
TARGET_ALLOC_EQUITIES=0.35
TARGET_ALLOC_PREDICTIONS=0.15
TARGET_ALLOC_CASH=0.10

# ---------------------------------------------------------------------------
# Engine — Circuit Breaker
# ---------------------------------------------------------------------------
CB_MAX_DAILY_LOSS=3.0                # % of capital
CB_MAX_DRAWDOWN=10.0                 # % of capital
CB_MAX_CONSECUTIVE_LOSSES=5
CB_MAX_ERROR_RATE=0.5                # error rate threshold
CB_COOLDOWN_MINUTES=60
CB_MANUAL_OVERRIDE=false

# ---------------------------------------------------------------------------
# Engine — Trade Guardrails
# ---------------------------------------------------------------------------
MAX_DAILY_TRADES=50
INSTRUMENT_WHITELIST=                # optional comma-separated list
LARGE_TRADE_THRESHOLD=10000          # USD threshold for alerts

# ---------------------------------------------------------------------------
# Coinbase / CDP (Crypto)
# ---------------------------------------------------------------------------
CDP_API_KEY_NAME=
CDP_API_KEY_SECRET=
CDP_NETWORK_ID=base-sepolia          # base-sepolia (testnet) or base-mainnet
CDP_WALLET_DATA_PATH=                # optional: path to persisted wallet data

# ---------------------------------------------------------------------------
# Alpaca (Equities)
# ---------------------------------------------------------------------------
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true                    # true = paper trading
ALPACA_DATA_URL=                     # defaults to Alpaca data URL
ALPACA_WS_URL=wss://stream.data.alpaca.markets/v2/iex

# ---------------------------------------------------------------------------
# Polymarket (Prediction Markets)
# ---------------------------------------------------------------------------
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_CLOB_URL=                 # defaults to Polymarket CLOB endpoint
POLYMARKET_GAMMA_URL=                # defaults to Polymarket Gamma endpoint
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_MARKETS=                  # comma-separated condition IDs for ingest

# ---------------------------------------------------------------------------
# Ingest Service
# ---------------------------------------------------------------------------
ENABLE_CRYPTO=true
ENABLE_EQUITIES=true
ENABLE_PREDICTION=true
CRYPTO_INSTRUMENTS=BTC-USD,ETH-USD,SOL-USD
EQUITY_SYMBOLS=SPY,QQQ,AAPL,MSFT,NVDA
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
CH_BATCH_SIZE=1000                   # ClickHouse batch insert size
CH_FLUSH_MS=5000                     # flush interval (ms)

# ---------------------------------------------------------------------------
# Google OAuth (Sign-In with Google)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=                    # Google Cloud Console → OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=               # Same value as GOOGLE_CLIENT_ID (Vite exposes to frontend)

# ---------------------------------------------------------------------------
# AI — Anthropic (Claude Agent SDK)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=                   # required when USE_CLAUDE_AGENTS=true

# ---------------------------------------------------------------------------
# Data Providers
# ---------------------------------------------------------------------------
FRED_API_KEY=                        # FRED macro data (free: https://fred.stlouisfed.org/docs/api/api_key.html)
CRYPTOPANIC_API_KEY=                 # CryptoPanic news sentiment (free: https://cryptopanic.com/developers/api/)

# ---------------------------------------------------------------------------
# Notifications (optional)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
