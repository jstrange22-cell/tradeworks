# ===================================
# TradeWorks Configuration
# ===================================
# Copy to .env and fill in values

# --- Database ---
DATABASE_URL=postgresql://tradeworks:tradeworks_dev@localhost:5432/tradeworks
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=tradeworks
REDIS_URL=redis://localhost:6379

# --- API Gateway ---
API_PORT=3001
JWT_SECRET=change-this-to-a-random-secret
CORS_ORIGINS=http://localhost:5173

# --- Engine ---
PAPER_TRADING=true
CYCLE_INTERVAL_MS=300000
MAX_BUDGET_PER_CYCLE_USD=5.00
ENABLED_MARKETS=crypto,prediction,equity

# --- Coinbase (CDP) ---
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_NETWORK_ID=base-sepolia

# --- Alpaca ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# --- Polymarket ---
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# --- Notifications (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
